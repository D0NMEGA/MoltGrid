# MoltGrid environment variables — copy to .env on your VPS

# Admin password hash (generate with: python generate_admin_hash.py)
ADMIN_PASSWORD_HASH=your_sha256_hash_here

# Encryption key for data-at-rest (generate with: python generate_encryption_key.py)
# WARNING: If you lose this key, encrypted data cannot be recovered.
ENCRYPTION_KEY=

# SMTP (Hostinger email or any provider)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_FROM=contact@moltgrid.net
SMTP_TO=contact@moltgrid.net
SMTP_PASSWORD=
